{
  "expo": {
    "name": "Domino Martiniquais",
    "slug": "domino-martinique",
    "version": "1.0.3",
    "orientation": "landscape",
    "icon": "./src/assets/images/icon.png",
    "scheme": "domino-martinique",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "statusBarHidden": true,
      "bundleIdentifier": "com.dominomartinique.mobile",
      "associatedDomains": [
        "applinks:domino-martinique.online"
      ]
    },
    "android": {
      "package": "com.dominomartinique.mobile",
      "versionCode": 4,
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "domino-martinique.online",
              "pathPrefix": "/join"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0d1f0d",
        "foregroundImage": "./src/assets/images/icon.png"
      },
      "statusBar": {
        "hidden": true
      }
    },
    "web": {
      "output": "single",
      "bundler": "metro",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#0d1f0d",
          "dark": {
            "backgroundColor": "#0d1f0d"
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "happy-agency"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/icon.png",
          "color": "#1A0E2E",
          "sounds": []
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": ""
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a9b61d5-b139-49ab-ae3a-752b9ae42898"
      }
    },
    "owner": "aboumalak",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3a9b61d5-b139-49ab-ae3a-752b9ae42898"
    }
  }
}
