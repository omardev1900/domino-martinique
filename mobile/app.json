{
  "expo": {
    "name": "Domino Martiniquais",
    "slug": "domino-martinique",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./src/assets/images/icon.png",
    "scheme": "domino-martinique",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "statusBarHidden": true,
      "bundleIdentifier": "com.dominomartinique.mobile"
    },
    "android": {
      "package": "com.dominomartinique.mobile",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "backgroundColor": "#0d1f0d",
        "foregroundImage": "./src/assets/images/icon.png"
      },
      "statusBar": {
        "hidden": true
      }
    },
    "web": {
      "output": "single",
      "bundler": "metro",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#0d1f0d",
          "dark": {
            "backgroundColor": "#0d1f0d"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/mobile"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c41e9fd3-2c51-4d26-874f-92f683280c81"
      }
    }
  }
}