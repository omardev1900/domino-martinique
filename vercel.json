{
    "headers": [
        {
            "source": "/.well-known/assetlinks.json",
            "headers": [
                { "key": "Content-Type", "value": "application/json" },
                { "key": "Cache-Control", "value": "public, max-age=3600" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/join/:code",
            "destination": "/join/index.html"
        },
        {
            "source": "/mobile",
            "destination": "/mobile/dist/index.html"
        },
        {
            "source": "/mobile/:path([^.]+)",
            "destination": "/mobile/dist/index.html"
        },
        {
            "source": "/mobile/:path*",
            "destination": "/mobile/dist/:path*"
        },
        {
            "source": "/((?!mobile|admin|api|join|\\.well-known|.*\\.apk|.*\\.css|.*\\.tsx|.*\\.js).*)",
            "destination": "/index.html"
        }
    ]
}
