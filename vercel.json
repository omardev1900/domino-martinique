{
    "rewrites": [
        {
            "source": "/mobile/:path*",
            "destination": "/mobile/dist/:path*"
        },
        {
            "source": "/mobile",
            "destination": "/mobile/dist/index.html"
        },
        {
            "source": "/((?!mobile|admin|api|.*\\.apk|.*\\.css|.*\\.tsx|.*\\.js).*)",
            "destination": "/index.html"
        }
    ]
}