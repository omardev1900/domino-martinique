rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonction helper : vérifie si l'utilisateur connecté est admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Collection admins : lisible uniquement par soi-même (pour vérifier son propre rôle)
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Jamais modifiable depuis le client
    }

    // Règle pour la collection des bots
    match /bots/{botId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Boutique (Store) : Un joueur peut VOIR le catalogue, mais NE DOIT PAS le modifier.
    match /store_catalog/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Règle pour les Rooms de jeu
    match /rooms/{roomId} {
      // Admin : accès complet
      allow read, write: if isAdmin();

      // Joueurs : création et lecture
      allow read, create: if request.auth != null;

      // Un joueur ne peut mettre à jour que s'il est dans la room (ou s'y ajoute)
      allow update: if request.auth != null && (request.auth.uid in resource.data.playerIds || request.auth.uid in request.resource.data.playerIds);

      // Seul le créateur (host) peut supprimer la room
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    // Tournois : lecture publique (pour l'app mobile), écriture admin uniquement
    match /tournaments/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Logs des actions admin : écriture par les admins authentifiés, lecture admin uniquement
    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Les logs sont immuables
    }

    // Configuration globale du jeu
    match /config/{docId} {
      allow read: if request.auth != null; // Lecture par tous (utile pour le mobile)
      allow write: if isAdmin();
    }

    // Règle pour les profils utilisateurs
    match /users/{userId} {
      // Admin : accès complet (lecture + modification pour bannissement, coins, etc.)
      allow read, write: if isAdmin();

      // Joueur : lecture de tous, écriture uniquement de son profil
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
